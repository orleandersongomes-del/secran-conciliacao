# Connection string do Postgres (Vercel Postgres / Neon)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Segredo do JWT (gere com: openssl rand -base64 32)
JWT_SECRET="troque-isso-para-um-valor-aleatorio-de-32-caracteres-no-minimo"

# URL pública do app (usada em links de emails, etc)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
